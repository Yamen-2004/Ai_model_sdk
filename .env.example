MAX_INSTALLMENT_RATIO=0.55
MAX_LOAN_DURATION_MONTHS=96
MAX_STATEMENT_AGE_DAYS=30

# Logging
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
